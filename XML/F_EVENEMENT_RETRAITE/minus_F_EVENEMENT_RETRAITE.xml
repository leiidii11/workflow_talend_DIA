"CREATE TEMPORARY TABLE DIA.TMP_EVENEMENT_RETRAITE_MINUS
as 
select
    ID_EVENEMENT,
    CD_STATUT,
    DT_MODIFICATION,
    DT_EFFET,
    PLUS_VALUE_TAXABLE,
    PRELEVEMENT_FISCAUX,
    PRELEVEMENT_SOCIAUX,
    TX_FRAIS_EVENEMENT,
    ID_CONTRAT,
    FK_D_CONTRAT_RETRAITE,
    FK_D_CONTRAT_RETRAITE_DERNIERE_VERSION,
    CD_EVENEMENT,
    FK_D_EVENEMENT_RETRAITE,
    getdate() as DT_CREA,
    getdate() as DT_MODIF
from dia.tmp_EVENEMENT_RETRAITE
minus
select
    ID_EVENEMENT,
    CD_STATUT,
    DT_MODIFICATION,
    DT_EFFET,
    PLUS_VALUE_TAXABLE,
    PRELEVEMENT_FISCAUX,
    PRELEVEMENT_SOCIAUX,
    TX_FRAIS_EVENEMENT,
    ID_CONTRAT,
    FK_D_CONTRAT_RETRAITE,
    FK_D_CONTRAT_RETRAITE_DERNIERE_VERSION,
    CD_EVENEMENT,
    FK_D_EVENEMENT_RETRAITE,
    getdate() as DT_CREA,
    getdate() as DT_MODIF
from dia.F_EVENEMENT_RETRAITE where sk_F_EVENEMENT_RETRAITE >0
"