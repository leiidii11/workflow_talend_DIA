"CREATE TEMPORARY TABLE DIA.TMP_F_EVENEMENT_DETAIL_RETRAITE_MINUS
as 
select
    ID_EVENEMENT_DETAIL,
    DT_COTATION,
    DT_EXECUTION,
    MT_EVENEMENT,
    MT_FRAIS,
    NB_PART,
    VALEUR_COTATION,
    ID_EVENEMENT,
    FK_F_EVENEMENT,
    ID_SUPPORT,
    FK_D_SUPPORT_RETRAITE,
    ID_CONTRAT,
    FK_F_VALORISATION_SUPPORT_CONTRAT_RETRAITE,
    ID_PROFIL_GESTION,
    FK_D_PROFIL_GESTION_RETRAITE,
    getdate() as DT_CREA,
    getdate() as DT_MODIF
from dia.tmp_F_EVENEMENT_DETAIL_RETRAITE
minus
select
    ID_EVENEMENT_DETAIL,
    DT_COTATION,
    DT_EXECUTION,
    MT_EVENEMENT,
    MT_FRAIS,
    NB_PART,
    VALEUR_COTATION,
    ID_EVENEMENT,
    FK_F_EVENEMENT,
    ID_SUPPORT,
    FK_D_SUPPORT_RETRAITE,
    ID_CONTRAT,
    FK_F_VALORISATION_SUPPORT_CONTRAT_RETRAITE,
    ID_PROFIL_GESTION,
    FK_D_PROFIL_GESTION_RETRAITE,
    getdate() as DT_CREA,
    getdate() as DT_MODIF
from dia.F_EVENEMENT_DETAIL_RETRAITE where sk_F_EVENEMENT_DETAIL_RETRAITE >0
"