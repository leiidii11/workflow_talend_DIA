"CREATE TEMPORARY TABLE DIA.TMP_D_ASSURE_RETRAITE_MINUS
as 
select
	ID_ASSURE,
	ID_PERSONNE_ASSURE,
	FK_D_PERSONNE_RETRAITE_ASSURE,
	ID_CONTRAT_RETRAITE,
	FK_D_CONTRAT_RETRAITE,
	getdate() as DT_CREA,
	getdate() as DT_MODIF
from dia.tmp_D_ASSURE_RETRAITE
minus
select
    ID_ASSURE,
	ID_PERSONNE_ASSURE,
	FK_D_PERSONNE_RETRAITE_ASSURE,
	ID_CONTRAT_RETRAITE,
	FK_D_CONTRAT_RETRAITE,
	getdate() as DT_CREA,
	getdate() as DT_MODIF
from dia.D_ASSURE_RETRAITE where sk_D_ASSURE_RETRAITE >0
"